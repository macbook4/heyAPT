{
  "name": "heyapt-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "pnpm --filter @heyapt/web dev",
    "build:web": "pnpm --filter @heyapt/web build",
    "test:web": "pnpm --filter @heyapt/web test"
  }
}
